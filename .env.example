# ==========================================
#  Telegram Media Downloader Bot
#  Environment Configuration
# ==========================================

# ─── Majburiy ────────────────────────────────────────────
# Telegram Bot Token (@BotFather'dan oling)
BOT_TOKEN=your_bot_token_here

# Redis ulanish URL'i
# Railway'da: Redis plugin avtomatik REDIS_URL beradi (bu qatorni qo'ymaysiz)
# Lokal Docker Compose: redis://redis:6379/0
# Lokal dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── Ixtiyoriy ───────────────────────────────────────────
# Admin Telegram ID'lar (vergul bilan ajratib)
ADMIN_IDS=

# Log darajasi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Yuklab olish sozlamalari ────────────────────────────
# Vaqtinchalik fayllar katalogi
# Linux/Docker: /tmp/media-bot
# Windows dev: ./tmp
TEMP_DIR=/tmp/media-bot

# Parallellik va rate limit
MAX_CONCURRENT_DOWNLOADS=20
MAX_PER_USER_DOWNLOADS=3
RATE_LIMIT_PER_MINUTE=5

# Maksimal fayl o'lchami (byte). 2GB = Local Bot API; 50MB = standart Bot API
MAX_FILE_SIZE=2147483648

# fastdl tezlashtiruvchi sozlamalari (fastdl o'rnatilgan bo'lsa)
fastdl_CONNECTIONS=16
fastdl_SPLIT=16
fastdl_MIN_SPLIT_SIZE=1M

# ─── Bot rejimi ──────────────────────────────────────────
# "polling" (tavsiya etilgan — sozlash kerak emas)
# "webhook" (ommaviy HTTPS URL kerak)
BOT_MODE=polling

# Webhook rejimida:
# WEBHOOK_URL — ommaviy HTTPS URL (masalan Railway domeni)
# Railway/Heroku/Render'da PORT env var avtomatik ishlatiladi
WEBHOOK_URL=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443

# ─── Qo'shimcha (odatda kerak emas) ─────────────────────
# Telegram Local Bot API Server (>50MB fayllar uchun)
LOCAL_BOT_API_URL=

# Instagram/YouTube cookies fayl yo'li (auth talab qiladigan kontent uchun)
COOKIES_FILE=

# HTTP/SOCKS5 proxy (geo-bloklangan kontent uchun)
# Masalan: http://user:pass@host:port yoki socks5://host:port
PROXY_URL=
